{
  "music": {
    "mode": "audio",
    "format": "mp3",
    "quality": "high",
    "output_dir": "Downloads/Music"
  },
  "video": {
    "mode": "video",
    "resolution": "1080",
    "output_dir": "Downloads/Videos"
  },
  "podcast": {
    "mode": "audio",
    "format": "mp3",
    "compress": true,
    "output_dir": "Downloads/Podcasts"
  },
  "mobile": {
    "mode": "video",
    "resolution": "720",
    "compress": true,
    "output_dir": "Downloads/Mobile"
  },
  "lecture": {
    "mode": "video",
    "resolution": "720",
    "compress": true,
    "audio_format": "mp3",
    "audio_output_dir": "Downloads/Lectures/Audio",
    "filename_template": "{uploader} - {title}.{ext}",
    "output_dir": "Downloads/Lectures"
  }
}
